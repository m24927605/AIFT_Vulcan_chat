# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Anthropic (fallback LLM)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LLM routing: openai | anthropic
PRIMARY_LLM=openai
# Fallback: openai | anthropic | "" (disabled)
FALLBACK_LLM=anthropic

# Tavily (web search)
TAVILY_API_KEY=tvly-your-tavily-api-key

# Fugle MarketData (Taiwan stock data, optional)
# Get API key at https://developer.fugle.tw
FUGLE_API_KEY=

# Finnhub (US/global stock + forex data, optional)
# Get API key at https://finnhub.io
FINNHUB_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Admin chat IDs (from @userinfobot), comma-separated
TELEGRAM_ADMIN_IDS=[123456789]

# API secret key (protects /api/notify and /api/notify/broadcast)
# Leave empty for development (no auth); set in production
API_SECRET_KEY=

# Startup mode: web | telegram | all
MODE=web

# Data directory for SQLite persistence (set to /data on Railway with a volume)
DATA_DIR=.
